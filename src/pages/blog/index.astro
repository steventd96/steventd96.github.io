---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

// Drafts show in dev but not in the production build.
const posts = (
  await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="All posts.">
  <div class="container rise">
    <header class="page-head prose">
      <p class="eyebrow">Writing</p>
      <h1>Blog</h1>
      <p class="muted">
        {posts.length} post{posts.length === 1 ? '' : 's'} on engineering,
        system design, and building things.
      </p>
    </header>

    <div class="post-grid">
      {
        posts.map((post) => (
          <PostCard
            url={`/blog/${post.id}/`}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
          />
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .page-head {
    margin-bottom: 2.5rem;
  }
  .page-head h1 {
    font-size: clamp(2rem, 5vw, 2.8rem);
    margin: 0.5rem 0 0.75rem;
  }
  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }
</style>
