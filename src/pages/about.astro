---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIALS } from '../consts';
---

<BaseLayout
  title="About"
  description="A little about Steven Dirjayanto — software engineer and writer."
>
  <div class="container">
    <article class="prose rise">
      <p class="eyebrow">About</p>
      <h1>Hi, I'm Steven.</h1>

      <p>
        Over the past five years I've gone from database and infrastructure
        engineering at Grab and TikTok to client engineering at IBM. This blog
        is where I document what I'm learning along the way — spanning software,
        system design, and the business of technology.
      </p>

      <p>
        If you're curious about that journey, my
        <a href="/blog/my-first-post/">first post</a> tells the full story.
      </p>

      <h2>Elsewhere</h2>
      <p>You can find me on:</p>
      <ul>
        <li><a href={SOCIALS.linkedin} target="_blank" rel="noopener">LinkedIn</a></li>
        <li><a href={SOCIALS.email}>Email</a></li>
      </ul>
    </article>
  </div>
</BaseLayout>

<style>
  .prose h1 {
    font-size: clamp(2rem, 5vw, 2.8rem);
    margin: 0.5rem 0 1.5rem;
  }
  .prose h2 {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 0.9rem;
  }
  .prose p {
    margin-bottom: 1.25rem;
    font-size: 1.1rem;
    line-height: 1.7;
  }
  .prose ul {
    margin: 0 0 1.25rem 1.25rem;
  }
  .prose li {
    margin-bottom: 0.5rem;
  }
</style>
