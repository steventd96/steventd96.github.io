---
import { SITE_TITLE, SOCIALS } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="muted">© {year} {SITE_TITLE}</p>
    <nav class="social" aria-label="Social links">
      <a href={SOCIALS.github} target="_blank" rel="noopener">GitHub</a>
      <a href={SOCIALS.twitter} target="_blank" rel="noopener">Twitter</a>
      <a href={SOCIALS.linkedin} target="_blank" rel="noopener">LinkedIn</a>
      <a href="/rss.xml">RSS</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding-block: 2rem;
    font-size: 0.9rem;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .social {
    display: flex;
    gap: 1.25rem;
  }
  .social a {
    color: var(--text-muted);
    font-weight: 500;
  }
  .social a:hover {
    color: var(--accent);
  }
</style>
