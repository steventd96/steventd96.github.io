---
import FormattedDate from './FormattedDate.astro';

interface Props {
  url: string;
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  minutesRead?: string;
}

const { url, title, description, pubDate, tags = [], minutesRead } =
  Astro.props;
---

<article class="card">
  <a href={url} class="card-link" aria-label={title}></a>
  <div class="card-meta">
    <FormattedDate date={pubDate} />
    {minutesRead && <span class="dot">·</span>}
    {minutesRead && <span>{minutesRead}</span>}
  </div>
  <h3 class="card-title">{title}</h3>
  <p class="card-desc muted">{description}</p>
  {
    tags.length > 0 && (
      <ul class="tags">
        {tags.slice(0, 3).map((t) => (
          <li>#{t}</li>
        ))}
      </ul>
    )
  }
</article>

<style>
  .card {
    position: relative;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-elev);
    transition: transform 0.2s var(--ease), border-color 0.2s var(--ease),
      box-shadow 0.2s var(--ease);
  }
  .card:hover {
    transform: translateY(-3px);
    border-color: var(--border-strong);
    box-shadow: var(--shadow);
  }
  /* Full-card click target without nesting anchors */
  .card-link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
  }
  .dot {
    opacity: 0.5;
  }
  .card-title {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
    transition: color 0.15s var(--ease);
  }
  .card:hover .card-title {
    color: var(--accent);
  }
  .card-desc {
    font-size: 0.98rem;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .tags {
    position: relative;
    z-index: 2;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
    padding: 0;
  }
  .tags li {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
  }
</style>
